# Server
PORT=3000
NODE_ENV=development

# Database (MySQL / Postgres / SQLite)
# DB_DIALECT can be: mysql | postgres | sqlite
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=attendance_db
DB_USER=root
DB_PASSWORD=yourpassword

# If using SQLite, set DB_DIALECT=sqlite and DB_NAME to a file path, e.g.
# DB_DIALECT=sqlite
# DB_NAME=./db/attendance.sqlite

# JWT
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Optional: Sequelize sync behavior (only use in development)
# DB_SYNC=false
# If set to true and DB_FORCE=true, Sequelize may drop/create tables.
# DB_FORCE=false
